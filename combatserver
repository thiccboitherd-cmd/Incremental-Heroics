EquipGearEvent.OnServerEvent:Connect(function(player, gearType, gearName)
	local pStats = player:FindFirstChild("PlayerStats")
	if pStats then
		local gearVal = pStats:FindFirstChild("Gear" .. gearType)
		if not gearVal then gearVal = Instance.new("StringValue", pStats); gearVal.Name = "Gear" .. gearType end
		gearVal.Value = gearName
	end
end)

EquipMoveEvent.OnServerEvent:Connect(function(player, slotIndex, moveId)
	local pStats = player:FindFirstChild("PlayerStats")
	if pStats then
		local slotVal = pStats:FindFirstChild("MoveSlot" .. slotIndex)
		if not slotVal then slotVal = Instance.new("StringValue", pStats); slotVal.Name = "MoveSlot" .. slotIndex end
		slotVal.Value = moveId
	end
end)

