-- CORE BATTLE LOGIC
-- ==========================================
local function CalculateTurnQueue()
	local sorted = {}
	for id, data in pairs(BattleState.Combatants) do
		if data.HP > 0 and not data.IsDead then table.insert(sorted, data) end
	end
	table.sort(sorted, function(a, b) return a.Stats.AGI > b.Stats.AGI end)
	BattleState.TurnQueue = {}
	for _, combatant in ipairs(sorted) do table.insert(BattleState.TurnQueue, combatant.Id) end
end

local function BroadcastState()
	local visualQueue = {}
	if BattleState.ActiveTurn ~= "" then table.insert(visualQueue, BattleState.ActiveTurn) end
	for _, id in ipairs(BattleState.TurnQueue) do table.insert(visualQueue, id) end

	local logToSend = BattleState.CurrentLog
	BattleState.CurrentLog = ""

	local clientData = {
		IsActive = BattleState.IsActive, TurnQueue = visualQueue, ActiveTurn = BattleState.ActiveTurn,
		Result = BattleState.Result, LogMessage = logToSend, Combatants = {}, AvailableMoves = {}
	}

	for id, data in pairs(BattleState.Combatants) do
		if not data.IsDead then
			clientData.Combatants[id] = { Name = data.Name, IsEnemy = data.IsEnemy, HP = data.HP, MaxHP = data.MaxHP, Status = data.Status, Portrait = data.Portrait }
		end
	end

	local activeEntity = BattleState.Combatants[BattleState.ActiveTurn]
	if activeEntity and not activeEntity.IsEnemy then
		for _, moveId in ipairs(activeEntity.EquippedMoves) do
			local md = MoveDatabase[moveId]
			if md then
				local state = "Normal"
				if activeEntity.Status.Type == "Erasure" and md.Type == "Quirk" then state = "Erasure" end
				if activeEntity.Status.Type == "Float" and (md.Type == "Style" or md.Type == "Basic") then state = "Erasure" end

				table.insert(clientData.AvailableMoves, {
					Id = moveId, Name = md.Name, Type = md.Type, Desc = md.Desc, IsQuirk = (md.Type == "Quirk"), State = state
				})
			end
		end
	end
	CombatUpdateEvent:FireAllClients(clientData)
end

local function ProcessStatusEffects(entity)
	if entity.Status.Type == "Normal" then return false end 
	local skipTurn = false
	local status = entity.Status

	if status.Type == "Burn" then
		local burnDmg = math.floor(entity.MaxHP * 0.05)
		entity.HP = math.clamp(entity.HP - burnDmg, 0, entity.MaxHP)
		AppendLog(entity.Name .. " took " .. burnDmg .. " " .. Colorize("Burn", "Burn") .. " damage!")
	elseif status.Type == "Bleed" then
		entity.HP = math.clamp(entity.HP - 50, 0, entity.MaxHP)
		AppendLog(entity.Name .. " took 50 " .. Colorize("Bleed", "Bleed") .. " damage!")
	elseif status.Type == "Stun" then
		AppendLog(entity.Name .. " is " .. Colorize("Stunned", "Stun") .. " and skipped their turn!")
		skipTurn = true 
	end

	status.Duration -= 1
	if status.Duration <= 0 then 
		if status.Type == "Overclock" then
			entity.Status = { Type = "Erasure", Duration = 3 }
			AppendLog(Colorize(entity.Name .. "'s engine stalled! Quirks locked for 3 turns.", "Erasure"))
		else
			entity.Status = { Type = "Normal", Duration = 0 } 
		end
	end
	return skipTurn
end

local function ProcessDamage(target, rawDamage)
	if not target then return 0 end
	local armorMitigation = target.Stats.END * 0.5 
	if target.Status.Type == "Corrode" then armorMitigation = 0 end 

	local finalDamage = math.floor(math.max(1, rawDamage - armorMitigation))
	if target.Status.Type == "Brittle" then finalDamage = math.floor(finalDamage * 1.5) end

	target.HP = math.clamp(target.HP - finalDamage, 0, target.MaxHP)
	return finalDamage
end

local function ExecuteAttack(user, target, moveData)
	if not user or not target then return end 
	if CalculateDodge(user, target) then
		AppendLog("-> But " .. target.Name .. " dodged the attack!")
	else
		local rawDmg = moveData.Execute(user, target)
		local finalDmg = ProcessDamage(target, rawDmg)
		if finalDmg > 1 then AppendLog("-> It dealt " .. finalDmg .. " damage to " .. target.Name .. ".") end
	end
end

local function NextTurn()
	if not BattleState.IsActive then return end
	if CheckBattleEnd() then BroadcastState(); return end

	if BattleState.IsGauntlet and not BattleState.ZeroPointerSpawned then
		local elapsedTime = os.time() - BattleState.StartTime
		if elapsedTime >= 480 then
			BattleState.ZeroPointerSpawned = true
			AppendLog(Colorize("WARNING: 2 MINUTES REMAINING! A colossal Zero-Pointer has entered the testing ground!", "Bleed"))

			local template = EnemyTemplates["0-Pointer"]
			local eId = "Enemy_Zero_" .. math.random(1000, 9999)

			BattleState.Combatants[eId] = {
				Id = eId, Name = template.Name, IsEnemy = true, IsDead = false,
				HP = template.HP, MaxHP = template.HP, Status = {Type = "Normal", Duration = 0}, 
				Portrait = template.Portrait, Stats = table.clone(template.Stats), 
				EquippedMoves = template.Moves, Cooldowns = {},
				Points = template.Points, Rewards = template.Rewards, IsBoss = template.IsBoss
			}
			CalculateTurnQueue() 
		end
	end

	if #BattleState.TurnQueue == 0 then CalculateTurnQueue() end

	BattleState.ActiveTurn = table.remove(BattleState.TurnQueue, 1)
	local activeEntity = BattleState.Combatants[BattleState.ActiveTurn]

	if not activeEntity or activeEntity.HP <= 0 or activeEntity.IsDead then NextTurn(); return end

	local skipTurn = ProcessStatusEffects(activeEntity)
	if activeEntity.HP <= 0 then NextTurn(); return end 

	if not activeEntity.IsEnemy then BroadcastState() end

	if skipTurn then 
		task.wait(1.5)
		ProcessDeaths()
		BroadcastState()
		NextTurn()
		return 
	end

	-- ENEMY AI
	if activeEntity.IsEnemy then
		task.wait(1.5)
		local target = nil
		for id, data in pairs(BattleState.Combatants) do
			if not data.IsEnemy and data.HP > 0 and not data.IsDead then target = data; break end
		end

		if target then
			for moveId, cd in pairs(activeEntity.Cooldowns) do
				if cd > 0 then activeEntity.Cooldowns[moveId] = cd - 1 end
			end

			local chosenMoveId = nil
			local highestPriority = 99

			for _, moveId in ipairs(activeEntity.EquippedMoves) do
				if (activeEntity.Cooldowns[moveId] or 0) <= 0 then
					local md = MoveDatabase[moveId]
					if md then
						local canUse = true
						if activeEntity.Status.Type == "Erasure" and md.Type == "Quirk" then canUse = false end
						if activeEntity.Status.Type == "Float" and (md.Type == "Style" or md.Type == "Basic") then canUse = false end

						if canUse then
							local priority = 4 
							if md.HasStatus then priority = 1
							elseif md.Type == "Quirk" then priority = 2
							elseif md.Type == "Style" then priority = 3 end

							if priority < highestPriority then
								highestPriority = priority; chosenMoveId = moveId
							end
						end
					end
				end
			end

			if chosenMoveId then
				local selectedMoveData = MoveDatabase[chosenMoveId]
				activeEntity.Cooldowns[chosenMoveId] = selectedMoveData.BaseCD or 0
				AppendLog(activeEntity.Name .. " used " .. selectedMoveData.Name .. "!")
				ExecuteAttack(activeEntity, target, selectedMoveData)
			else
				AppendLog(activeEntity.Name .. " struggled but couldn't use any moves!")
			end
		end

		ProcessDeaths()
		BroadcastState()
		task.wait(1)
		NextTurn()
	end
end

-- LISTEN FOR PLAYER ATTACKS
CombatActionEvent.OnServerEvent:Connect(function(player, moveId, targetId)
	if not BattleState.IsActive then return end
	if BattleState.ActiveTurn ~= player.Name then return end 

	BattleState.ActiveTurn = "Processing"

	local user = BattleState.Combatants[player.Name]
	local moveData = MoveDatabase[moveId]
	local primaryTarget = BattleState.Combatants[targetId]

	if user and moveData then
		if user.Status.Type == "Erasure" and moveData.Type == "Quirk" then return end
		if user.Status.Type == "Float" and (moveData.Type == "Style" or moveData.Type == "Basic") then return end

		if moveData.IsAoE then
			AppendLog(user.Name .. " used AoE: " .. moveData.Name .. "!")
			for id, data in pairs(BattleState.Combatants) do
				if data.IsEnemy and data.HP > 0 and not data.IsDead then ExecuteAttack(user, data, moveData) end
			end
		elseif primaryTarget and primaryTarget.IsEnemy and primaryTarget.HP > 0 and not primaryTarget.IsDead then
			AppendLog(user.Name .. " used " .. moveData.Name .. " against " .. primaryTarget.Name .. "!")
			ExecuteAttack(user, primaryTarget, moveData)
		else
			BattleState.ActiveTurn = player.Name
			return 
		end

		ProcessDeaths()
		BroadcastState()
		task.wait(1)
		NextTurn()
	end
end)

-- STORY MODE ENCOUNTER GENERATOR
StartCombatEvent.OnServerEvent:Connect(function(player, zoneId)
	if BattleState.IsActive then return end

	local pStats = player:FindFirstChild("PlayerStats")
	local highestZone = (pStats and pStats:FindFirstChild("HighestZoneCleared")) and pStats.HighestZoneCleared.Value or 0
	local isGauntlet = (zoneId == "1" and highestZone < 1)

	BattleState.IsActive = true
	BattleState.Result = nil
	BattleState.CurrentLog = "Encounter started! Zone " .. zoneId
	BattleState.Combatants = {}
	BattleState.IsGauntlet = isGauntlet
	BattleState.ZoneId = zoneId
	BattleState.Wave = 1
	BattleState.ExamPoints = 0
	BattleState.AccumulatedRewards = { HeroCoins = 0, TrainingXP = 0, Spins = 0, MasteryXP = 0 }
	BattleState.StartTime = os.time()
	BattleState.ZeroPointerSpawned = false

	local playerMoves = {}
	if pStats then
		for i = 1, 4 do
			local slotVal = pStats:FindFirstChild("MoveSlot" .. i)
			if slotVal and slotVal.Value ~= "" and slotVal.Value ~= "Empty" then
				table.insert(playerMoves, slotVal.Value)
			end
		end
	end
	if #playerMoves == 0 then table.insert(playerMoves, "basic_strike") end

	local baseSTR = (pStats and pStats:FindFirstChild("Strength")) and math.max(pStats.Strength.Value, 100) or 100
	local baseAGI = (pStats and pStats:FindFirstChild("Agility")) and math.max(pStats.Agility.Value, 100) or 100
	local baseEND = (pStats and pStats:FindFirstChild("Endurance")) and math.max(pStats.Endurance.Value, 50)  or 50
	local baseQF  = (pStats and pStats:FindFirstChild("QuirkFactor")) and math.max(pStats.QuirkFactor.Value, 100) or 100

	local finalStats = { STR = baseSTR, AGI = baseAGI, END = baseEND, QF = baseQF }

	if pStats then
		local gearTypes = {"WEAPON", "ARMOR", "ASSIST"}
		for _, gType in ipairs(gearTypes) do
			local gVal = pStats:FindFirstChild("Gear" .. gType)
			if gVal and gVal.Value ~= "" and GearDatabase[gVal.Value] then
				local bonus = GearDatabase[gVal.Value].Stats
				finalStats.STR += bonus.STR
				finalStats.AGI += bonus.AGI
				finalStats.END += bonus.END
				finalStats.QF  += bonus.QF
			end
		end
	end

	local finalMaxHP = 1000 + (finalStats.END * 10)

	BattleState.Combatants[player.Name] = {
		Id = player.Name, Name = player.Name, IsEnemy = false, IsDead = false,
		HP = finalMaxHP, MaxHP = finalMaxHP, Status = {Type = "Normal", Duration = 0}, 
		Portrait = "https://www.roblox.com/headshot-thumbnail/image?userId="..player.UserId.."&width=150&height=150&format=png",
		Stats = finalStats, 
		EquippedMoves = playerMoves, 
		Cooldowns = {}
	}

	if isGauntlet then
		SpawnWave()
	else
		local template = EnemyTemplates["0-Pointer"]
		BattleState.Combatants["Boss_0Pointer"] = {
			Id = "Boss_0Pointer", Name = template.Name, IsEnemy = true, IsDead = false,
			HP = template.HP, MaxHP = template.HP, Status = {Type = "Normal", Duration = 0}, 
			Portrait = template.Portrait, Stats = table.clone(template.Stats), 
			EquippedMoves = template.Moves, Cooldowns = {}, Points = template.Points, 
			Rewards = template.Rewards, IsBoss = true
		}
	end

	CalculateTurnQueue()
	NextTurn()
end)
