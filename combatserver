local function CalculateDodge(user, target)
	if not user or not target then return false end 
	local dodgeChance = 5 + math.max(0, (target.Stats.AGI - user.Stats.AGI) / 5)
	return math.random(1, 100) <= math.clamp(dodgeChance, 5, 50)
end

-- MISSING FUNCTION RESTORED!
local function AwardRewards()
	for id, data in pairs(BattleState.Combatants) do
		if not data.IsEnemy then
			local plr = Players:FindFirstChild(id)
			if plr and plr:FindFirstChild("PlayerStats") then
				local pStats = plr.PlayerStats

				for rewardName, amount in pairs(BattleState.AccumulatedRewards) do
					if rewardName == "MasteryXP" then
						if pStats:FindFirstChild("QuirkMasteryXP") then pStats.QuirkMasteryXP.Value += amount end
						if pStats:FindFirstChild("StyleMasteryXP") then pStats.StyleMasteryXP.Value += amount end
					else
						local statVal = pStats:FindFirstChild(rewardName)
						if statVal and statVal:IsA("IntValue") then
							statVal.Value += amount
						end
					end
				end
			end
		end
	end
end

local function ProcessDeaths()
	for id, data in pairs(BattleState.Combatants) do
		if data.HP <= 0 and not data.IsDead then
			data.IsDead = true

			if data.IsEnemy then
				BattleState.ExamPoints += (data.Points or 0)

				if data.Rewards then
					for rewardName, amount in pairs(data.Rewards) do
						BattleState.AccumulatedRewards[rewardName] = (BattleState.AccumulatedRewards[rewardName] or 0) + amount
					end
				end

				AppendLog(Colorize(data.Name .. " destroyed! (+" .. (data.Points or 0) .. " Pts)", "Stun"))

				if data.IsBoss and math.random(1, 100) <= 25 then
					BattleState.AccumulatedRewards["SupportGearBox"] = (BattleState.AccumulatedRewards["SupportGearBox"] or 0) + 1
					AppendLog(Colorize("A Support Gear Box dropped!", "Brittle"))
				end
			else
				AppendLog(Colorize(data.Name .. " was knocked out!", "Bleed"))
			end
		end
	end
end

local function EvaluateGauntlet()
	BattleState.IsActive = false

	if BattleState.ExamPoints >= 50 then
		local bonusMult = 1
		local title = "EXAM PASSED!"

		if BattleState.ExamPoints > 76 then
			bonusMult = 2
			title = "NUMBER 1 EXAMINEE! (2X REWARDS)"
		end

		for k, v in pairs(BattleState.AccumulatedRewards) do
			BattleState.AccumulatedRewards[k] = v * bonusMult
		end

		AppendLog(Colorize(title .. " Total Points: " .. BattleState.ExamPoints, "Stun"))
		BattleState.Result = { Type = "Victory", Rewards = BattleState.AccumulatedRewards }

		for id, data in pairs(BattleState.Combatants) do
			if not data.IsEnemy then
				local plr = Players:FindFirstChild(id)
				if plr and plr:FindFirstChild("PlayerStats") then
					local hz = plr.PlayerStats:FindFirstChild("HighestZoneCleared")
					if not hz then hz = Instance.new("IntValue", plr.PlayerStats); hz.Name = "HighestZoneCleared" end
					if hz.Value < 1 then hz.Value = 1 end
				end
			end
		end
	else
		AppendLog(Colorize("EXAM FAILED. You scored " .. BattleState.ExamPoints .. " / 50 points.", "Bleed"))
		BattleState.Result = { Type = "Defeat", Rewards = BattleState.AccumulatedRewards } 
	end

	AwardRewards() 
end

local function SpawnWave()
	AppendLog(Colorize("--- WAVE " .. BattleState.Wave .. " APPROACHING! ---", "Burn"))
	BattleState.Wave += 1

	for id, data in pairs(BattleState.Combatants) do
		if data.IsEnemy then BattleState.Combatants[id] = nil end
	end

	local numEnemies = math.random(1, 3)
	for i = 1, numEnemies do
		local roll = math.random(1, 100)
		local enemyType = ""

		if roll <= 50 then enemyType = "1-Pointer"
		elseif roll <= 80 then enemyType = "2-Pointer"
		elseif roll <= 95 then enemyType = "3-Pointer"
		elseif roll <= 99 then enemyType = "0-Pointer"
		else enemyType = "Present Mic" end

		local template = EnemyTemplates[enemyType]
		local eId = "Enemy_"..i.."_"..math.random(1000,9999)

		BattleState.Combatants[eId] = {
			Id = eId, Name = template.Name, IsEnemy = true, IsDead = false,
			HP = template.HP, MaxHP = template.HP, Status = {Type = "Normal", Duration = 0}, 
			Portrait = template.Portrait, Stats = table.clone(template.Stats), 
			EquippedMoves = template.Moves, Cooldowns = {},
			Points = template.Points, Rewards = template.Rewards, IsBoss = template.IsBoss
		}
	end
end

local function CheckBattleEnd()
	ProcessDeaths() 

	if BattleState.IsGauntlet then
		local elapsedTime = os.time() - BattleState.StartTime
		if elapsedTime >= 600 then
			AppendLog(Colorize("BUZZER SOUNDS! The 10-minute exam is over!", "Stun"))
			EvaluateGauntlet()
			return true
		end
	end

	local playersAlive, enemiesAlive = false, false
	for id, data in pairs(BattleState.Combatants) do
		if not data.IsDead then
			if data.IsEnemy then enemiesAlive = true else playersAlive = true end
		end
	end

	if not playersAlive then
		if BattleState.IsGauntlet then
			EvaluateGauntlet()
		else
			BattleState.IsActive = false
			BattleState.Result = { Type = "Defeat", Rewards = BattleState.AccumulatedRewards }
			AwardRewards()
		end
		return true
	elseif not enemiesAlive then
		if BattleState.IsGauntlet then
			SpawnWave() 
			return false 
		else
			BattleState.IsActive = false
			BattleState.Result = { Type = "Victory", Rewards = BattleState.AccumulatedRewards }
			AwardRewards()
			return true
		end
	end
	return false
end

