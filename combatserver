-- BATTLE ENGINE STATE & LOGGING
-- ==========================================
local BattleState = {
	IsActive = false, TurnQueue = {}, ActiveTurn = "", Combatants = {}, Result = nil, CurrentLog = "",
	IsGauntlet = false, ZoneId = "1", Wave = 1, ExamPoints = 0, AccumulatedRewards = {},
	StartTime = 0, ZeroPointerSpawned = false
}

local StatusColors = {
	Burn = "#FF5500", Bleed = "#CC0000", Stun = "#FFFF00", 
	Corrode = "#32CD32", Hardened = "#A9A9A9", Brittle = "#87CEFA", 
	Erasure = "#800080", Float = "#DDA0DD", Overclock = "#FF8C00" 
}

local function Colorize(text, status)
	local hex = StatusColors[status] or "#FFFFFF"
	return string.format("<font color='%s'><b>%s</b></font>", hex, text)
end

local function AppendLog(msg)
	if BattleState.CurrentLog == "" then BattleState.CurrentLog = msg else BattleState.CurrentLog = BattleState.CurrentLog .. " " .. msg end
	print("LOG:", msg) 
end

local function ApplyStatus(target, statusType, duration)
	if not target then return end
	target.Status = { Type = statusType, Duration = duration }
	AppendLog("It inflicted " .. Colorize(statusType, statusType) .. "!")
end

