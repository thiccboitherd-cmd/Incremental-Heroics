local function switchTab(tabName: string)
	for name, page in pairs(pages) do
		if name == tabName then
			page.Visible = true
			-- Fade in
			local contentScale = page:FindFirstChildWhichIsA("UIScale")
			if not contentScale then
				contentScale = Instance.new("UIScale", page)
			end
			contentScale.Scale = 0.97
			TweenService:Create(contentScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1}):Play()
		else
			page.Visible = false
		end
		if navButtons[name] then
			if name == tabName then
				navButtons[name].Gui.TextColor3 = Color3.fromRGB(115, 195, 235)
				navButtons[name].Gui.Font = Enum.Font.GothamBold
				-- Move indicator
				if navButtons[name].Gui.AbsolutePosition then
					tabIndicator.Visible = true
					TweenService:Create(tabIndicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
						Position = UDim2.new(0, navButtons[name].Gui.AbsolutePosition.X - topBar.Gui.AbsolutePosition.X, 1, -3),
						Size = UDim2.new(0, navButtons[name].Gui.AbsoluteSize.X, 0, 3)
					}):Play()
				end
			else
				navButtons[name].Gui.TextColor3 = Theme.Colors.Text
				navButtons[name].Gui.Font = Enum.Font.Gotham
			end
		end
	end

	currentTab = tabName
	if shared_mapOverlay then
		shared_mapOverlay.Visible = false
	end
end

