-- ==========================================
-- NEW: HOVER EFFECT SYSTEM
-- Adds a subtle scale/brightness tween when hovering over any GuiButton
-- ==========================================
local function applyHoverEffect(btn: GuiButton, scaleUp: number?, brightenBy: number?)
	local targetScale = scaleUp or 1.04
	local dimScale = 1 / targetScale
	local uiScale = btn:FindFirstChildWhichIsA("UIScale")
	if not uiScale then
		uiScale = Instance.new("UIScale", btn)
		uiScale.Scale = 1
	end
	local origColor = btn.BackgroundColor3
	btn.MouseEnter:Connect(function()
		TweenService:Create(uiScale, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = targetScale}):Play()
		if brightenBy then
			local r = math.clamp(origColor.R + brightenBy/255, 0, 1)
			local g = math.clamp(origColor.G + brightenBy/255, 0, 1)
			local b = math.clamp(origColor.B + brightenBy/255, 0, 1)
			TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.new(r, g, b)}):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(uiScale, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1}):Play()
		if brightenBy then
			TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = origColor}):Play()
		end
	end)
	btn.MouseButton1Down:Connect(function()
		TweenService:Create(uiScale, TweenInfo.new(0.06), {Scale = dimScale}):Play()
	end)
	btn.MouseButton1Up:Connect(function()
		TweenService:Create(uiScale, TweenInfo.new(0.1, Enum.EasingStyle.Back), {Scale = targetScale}):Play()
	end)
end

