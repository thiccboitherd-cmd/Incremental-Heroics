local toastCounter = 0
local function showToast(message: string, color: Color3?, duration: number?, icon: string?)
	if not toastContainer then return end
	toastCounter += 1
	local toastColor = color or Color3.fromRGB(50, 220, 100)
	local toastDuration = duration or 2.8

	local toastFrame = Instance.new("Frame", toastContainer)
	toastFrame.Name = "Toast_" .. toastCounter
	toastFrame.Size = UDim2.new(1, 0, 0, 40)
	toastFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
	toastFrame.BorderSizePixel = 0
	toastFrame.BackgroundTransparency = 1
	toastFrame.LayoutOrder = -toastCounter
	local corner = Instance.new("UICorner", toastFrame)
	corner.CornerRadius = UDim.new(0, 8)

	local leftAccent = Instance.new("Frame", toastFrame)
	leftAccent.Size = UDim2.new(0, 4, 1, 0)
	leftAccent.BackgroundColor3 = toastColor
	leftAccent.BorderSizePixel = 0
	leftAccent.BackgroundTransparency = 1
	local accentCorner = Instance.new("UICorner", leftAccent)
	accentCorner.CornerRadius = UDim.new(0, 4)

	local label = Instance.new("TextLabel", toastFrame)
	label.Size = UDim2.new(1, -18, 1, 0)
	label.Position = UDim2.new(0, 14, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = message
	label.TextColor3 = Color3.fromRGB(230, 230, 240)
	label.TextSize = 13
	label.Font = Enum.Font.GothamBold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextWrapped = true
	label.TextTransparency = 1

	local stroke = Instance.new("UIStroke", toastFrame)
	stroke.Color = toastColor
	stroke.Thickness = 1
	stroke.Transparency = 1

	-- Slide in from right
	toastFrame.Position = UDim2.new(1.1, 0, 0, 0)
	TweenService:Create(toastFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {BackgroundTransparency = 0.12}):Play()
	TweenService:Create(leftAccent, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
	TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0.6}):Play()
	TweenService:Create(label, TweenInfo.new(0.25), {TextTransparency = 0}):Play()

	task.delay(toastDuration, function()
		TweenService:Create(toastFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, Position = UDim2.new(1.1, 0, 0, 0)}):Play()
		TweenService:Create(label, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
		TweenService:Create(leftAccent, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
		task.wait(0.45)
		toastFrame:Destroy()
	end)
end

