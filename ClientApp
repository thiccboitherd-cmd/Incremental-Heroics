-- COMBAT STATE MANAGER (SERVER -> CLIENT)
-- ==========================================
local combatantCards = {}
local selectedTargetId = nil

local function updateCombatUI(combatState)
	if not combatState.IsActive and combatState.Result then
		shared_resultOverlay.Visible = true

		for _, child in ipairs(shared_rewardsContainer:GetChildren()) do
			if child:IsA("TextLabel") or child:IsA("Frame") then child:Destroy() end
		end

		if combatState.Result.Type == "Victory" then
			shared_resultTitle:SetText("⚡ VICTORY!")
			shared_resultTitle.Gui.TextColor3 = Color3.fromRGB(255, 215, 0)
			shared_resultDesc:SetText("Zone cleared. Rewards acquired:")

			local resultAccent = shared_resultOverlay:FindFirstChild("ResultPanel") and shared_resultOverlay.ResultPanel:FindFirstChild("Frame")
			if resultAccent then resultAccent.BackgroundColor3 = Color3.fromRGB(255, 215, 0) end

			for rewardName, amount in pairs(combatState.Result.Rewards) do
				local rewardRow = Instance.new("Frame", shared_rewardsContainer)
				rewardRow.Size = UDim2.new(1, 0, 0, 28)
				rewardRow.BackgroundColor3 = Color3.fromRGB(20, 30, 20)
				rewardRow.BorderSizePixel = 0
				local rrc = Instance.new("UICorner", rewardRow); rrc.CornerRadius = UDim.new(0, 6)

				local rLabel = Instance.new("TextLabel", rewardRow)
				rLabel.Size = UDim2.new(1, -16, 1, 0)
				rLabel.Position = UDim2.new(0, 10, 0, 0)
				rLabel.BackgroundTransparency = 1
				rLabel.Text = "+ " .. amount .. "  " .. rewardName
				rLabel.TextColor3 = Color3.fromRGB(80, 220, 100)
				rLabel.Font = Enum.Font.GothamBold
				rLabel.TextSize = 13
				rLabel.TextXAlignment = Enum.TextXAlignment.Left
			end

			showToast("⚡ VICTORY! Zone cleared!", Color3.fromRGB(255, 215, 0), 4)
		else
			shared_resultTitle:SetText("✕ DEFEAT")
			shared_resultTitle.Gui.TextColor3 = Color3.fromRGB(220, 50, 50)
			shared_resultDesc:SetText("Your team was wiped out. Train harder and retry.")
			showToast("💀 Defeated... Review your loadout and try again.", Color3.fromRGB(220, 80, 80), 4)
		end

		combatantCards = {}
		selectedTargetId = nil
		return
	end

	-- Clear and rebuild turn order
	for _, child in ipairs(shared_turnOrderPanelGui:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("TextLabel") then
			child:Destroy()
		end
	end

	for _, combatantId in ipairs(combatState.TurnQueue) do
		local data = combatState.Combatants[combatantId]
		if data then
			addToTurnOrder(data.Portrait, data.IsEnemy, combatantId == combatState.ActiveTurn)
		end
	end

	local firstAliveEnemy = nil
	local allyCount = 0
	local isMyTurn = (combatState.ActiveTurn == player.Name)

	-- Update turn indicator text in combat moves panel
	if shared_turnIndicator then
		if isMyTurn then
			shared_turnIndicator.Text = "⚡ YOUR TURN — SELECT A MOVE"
			shared_turnIndicator.TextColor3 = Color3.fromRGB(80, 220, 100)
		else
			shared_turnIndicator.Text = "WAITING FOR TURN..."
			shared_turnIndicator.TextColor3 = Color3.fromRGB(100, 100, 120)
		end
	end

	for id, data in pairs(combatState.Combatants) do
		local cardData = combatantCards[id]

		if not data.IsEnemy then allyCount += 1 end

		if not cardData then
			local isBoss = data.IsBoss or false
			cardData = createCombatant(data.Name, data.IsEnemy, data.MaxHP, data.Portrait, isBoss)
			cardData.CurrentHP = data.HP
			combatantCards[id] = cardData

			if data.IsEnemy then
				local targetBtn = Instance.new("TextButton", cardData.Card)
				targetBtn.Size = UDim2.new(1, 0, 1, 0)
				targetBtn.BackgroundTransparency = 1
				targetBtn.Text = ""
				targetBtn.ZIndex = 5

				targetBtn.MouseButton1Click:Connect(function()
					if combatState.Combatants[id] and combatState.Combatants[id].HP > 0 then
						selectedTargetId = id
						for eId, eCard in pairs(combatantCards) do
							if combatState.Combatants[eId] and combatState.Combatants[eId].IsEnemy then
								if eId == selectedTargetId then
									eCard.TurnStroke.Color = Color3.fromRGB(255, 50, 50)
									eCard.TurnStroke.Transparency = 0
								else
									eCard.TurnStroke.Transparency = 1
								end
							end
						end
					end
				end)
			end
		end

		local hpPercent = math.clamp(data.HP / data.MaxHP, 0, 1)
		if data.HP < (cardData.CurrentHP or data.MaxHP) then
			cardData.TriggerDamage()
			-- Spawn floating damage number above the card
			local dmgAmount = (cardData.CurrentHP or data.MaxHP) - data.HP
			if dmgAmount > 0 and floatingTextLayer then
				-- Estimate screen position from card AbsolutePosition
				task.spawn(function()
					RunService.RenderStepped:Wait()
					local absPos = cardData.Card.AbsolutePosition
					local absSize = cardData.Card.AbsoluteSize
					local screenCenter = UDim2.new(
						0, absPos.X + absSize.X / 2,
						0, absPos.Y + 20
					)
					-- Convert to scale
					local vp = game.Workspace.CurrentCamera.ViewportSize
					local scaledPos = UDim2.new(
						(absPos.X + absSize.X / 2) / vp.X, 0,
						(absPos.Y + 20) / vp.Y, 0
					)
					local isCrit = dmgAmount > data.MaxHP * 0.15
					spawnFloatingText(
						(isCrit and "💥 " or "") .. "-" .. math.floor(dmgAmount),
						data.IsEnemy and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(255, 200, 80),
						scaledPos,
						isCrit
					)
				end)
			end
		end

		cardData.CurrentHP = data.HP
		cardData.HPBar:SetProgress(hpPercent)
		if cardData.HPText then
			cardData.HPText:SetText(math.floor(data.HP) .. "/" .. math.floor(data.MaxHP))
		end

		local statusType = type(data.Status) == "table" and data.Status.Type or data.Status
		cardData.ApplyStatus(statusType or "Normal")

		if data.IsEnemy and data.HP > 0 and not firstAliveEnemy then
			firstAliveEnemy = id
		end

		if id == combatState.ActiveTurn then
			cardData.TurnStroke.Color = Color3.fromRGB(255, 255, 100)
			cardData.TurnStroke.Transparency = 0
		elseif data.IsEnemy and id == selectedTargetId then
			cardData.TurnStroke.Color = Color3.fromRGB(255, 50, 50)
			cardData.TurnStroke.Transparency = 0
		else
			cardData.TurnStroke.Transparency = 1
		end
	end

	if (not selectedTargetId or (combatState.Combatants[selectedTargetId] and combatState.Combatants[selectedTargetId].HP <= 0)) and firstAliveEnemy then
		selectedTargetId = firstAliveEnemy
		if combatantCards[selectedTargetId] then
			combatantCards[selectedTargetId].TurnStroke.Color = Color3.fromRGB(255, 50, 50)
			combatantCards[selectedTargetId].TurnStroke.Transparency = 0
		end
	end

	for id, cardData in pairs(combatantCards) do
		if not combatState.Combatants[id] then
			cardData.Card:Destroy()
			combatantCards[id] = nil
		end
	end

	clearContainer(shared_movesScrollGui)

	for i, move in ipairs(combatState.AvailableMoves) do
		local moveData = createMove(i, move.Name, move.Type, move.Desc, move.IsQuirk)
		moveData.SetState(move.State)

		if not isMyTurn or move.State == "Erasure" then
			moveData.Button.Gui.Active = false
			moveData.Button.Gui.BackgroundTransparency = 0.6
		else
			moveData.Button:OnClick(function()
				if selectedTargetId then
					CombatActionEvent:FireServer(move.Id, selectedTargetId)
					for _, child in ipairs(shared_movesScrollGui:GetChildren()) do
						if child:IsA("TextButton") then
							child.Active = false
							child.BackgroundTransparency = 0.6
						end
					end
				end
			end)
		end
	end

	if combatState.LogMessage and combatState.LogMessage ~= "" then
		if shared_combatLogText then
			local currentAnimTicket = os.clock()
			shared_combatLogText.Gui:SetAttribute("AnimTicket", currentAnimTicket)
			shared_combatLogText:SetText(combatState.LogMessage)
			RunService.RenderStepped:Wait()

			local cleanTextLength = utf8.len(shared_combatLogText.Gui.ContentText) or string.len(shared_combatLogText.Gui.ContentText)

			local isSoloPlay = (allyCount == 1)
			local skipConnection
			if isSoloPlay and shared_skipLogBtn then
				skipConnection = shared_skipLogBtn.MouseButton1Click:Connect(function()
					shared_combatLogText.Gui:SetAttribute("AnimTicket", -1)
					shared_combatLogText.Gui.MaxVisibleGraphemes = cleanTextLength
				end)
			end

			task.spawn(function()
				shared_combatLogText.Gui.MaxVisibleGraphemes = 0
				for i = 1, cleanTextLength do
					if shared_combatLogText.Gui:GetAttribute("AnimTicket") ~= currentAnimTicket then break end
					shared_combatLogText.Gui.MaxVisibleGraphemes = i
					task.wait(0.005)
				end
				shared_combatLogText.Gui.MaxVisibleGraphemes = cleanTextLength
				if skipConnection then skipConnection:Disconnect() end
			end)
		end
	end
end

