-- ==========================================
-- NEW: ANIMATED COUNTER (smooth number transitions)
-- ==========================================
local function animateCounter(label: any, fromVal: number, toVal: number, prefix: string, suffix: string, duration: number?)
	local dur = duration or 0.5
	local startTime = os.clock()
	local diff = toVal - fromVal
	local connection
	connection = RunService.RenderStepped:Connect(function()
		local elapsed = math.min(os.clock() - startTime, dur)
		local t = elapsed / dur
		-- Ease out cubic
		t = 1 - (1 - t)^3
		local current = math.floor(fromVal + diff * t)
		label:SetText(prefix .. current .. suffix)
		if elapsed >= dur then
			label:SetText(prefix .. toVal .. suffix)
			connection:Disconnect()
		end
	end)
end

