	local function getRandomItem(category: string): string
		local pool = GachaPools[category]
		local rarities = {"Trash", "Common", "Uncommon", "Rare", "Elite", "Epic", "Legendary", "Mythic", "Secret"}
		local r = rarities[math.random(1, #rarities)]
		if pool[r] and #pool[r] > 0 then return pool[r][math.random(1, #pool[r])] end
		return "None"
	end

	local function shakeUI(uiElement: Instance, intensity: number, duration: number)
		local origPos = uiElement.Position
		local elapsed = 0
		local connection
		connection = RunService.RenderStepped:Connect(function(dt)
			elapsed += dt
			if elapsed >= duration then
				connection:Disconnect()
				uiElement.Position = origPos
			else
				local offsetX = math.random(-intensity, intensity)
				local offsetY = math.random(-intensity, intensity)
				uiElement.Position = origPos + UDim2.new(0, offsetX, 0, offsetY)
			end
		end)
	end

	shared_playGachaAnimation = function(category: string, finalItem: string, onComplete)
		shared_isRollingActive = true
		gachaOverlay.Visible = true
		gachaCategoryLabel:SetText("ROLLING " .. string.upper(category) .. "...")
		gachaRarityLabel:SetText("")
		gachaScale.Scale = 1
		rarityAura.BackgroundTransparency = 1

		TweenService:Create(gachaOverlay, TweenInfo.new(0.3), {BackgroundTransparency = 0.15}):Play()

		-- Faster spin-up with acceleration
		for i = 1, 18 do
			local randomItem = getRandomItem(category)
			local randomRarity = getRarity(category, randomItem)
			gachaResultLabel:SetText(randomItem)
			gachaResultLabel.Gui.TextColor3 = RarityColors[randomRarity]

			gachaScale.Scale = 0.96
			TweenService:Create(gachaScale, TweenInfo.new(0.04, Enum.EasingStyle.Sine), {Scale = 1.04}):Play()
			task.wait(0.04 + (i * 0.004))
		end

		local finalRarity = getRarity(category, finalItem)
		local rColor = RarityColors[finalRarity]

		-- Show aura glow
		rarityAura.BackgroundColor3 = rColor
		TweenService:Create(rarityAura, TweenInfo.new(0.4), {BackgroundTransparency = 0.75}):Play()

		gachaCategoryLabel:SetText("◆ NEW " .. string.upper(category) .. " ◆")
		gachaResultLabel:SetText(string.upper(finalItem))
		gachaResultLabel.Gui.TextColor3 = rColor
		resultStroke.Color = rColor == Color3.fromRGB(255, 255, 255) and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(10, 10, 18)
		gachaRarityLabel:SetText("• " .. string.upper(finalRarity) .. " •")
		gachaRarityLabel.Gui.TextColor3 = rColor

		lineL.BackgroundColor3 = rColor
		lineR.BackgroundColor3 = rColor

		local impactLevel = 0
		if finalRarity == "Secret" or finalRarity == "Mythic" or finalRarity == "Legendary" then impactLevel = 3
		elseif finalRarity == "Epic" or finalRarity == "Elite" then impactLevel = 2
		elseif finalRarity == "Rare" or finalRarity == "Uncommon" then impactLevel = 1 end

		if impactLevel == 3 then
			-- Multi-flash effect
			for _ = 1, 3 do
				flashFrame.BackgroundColor3 = rColor
				flashFrame.BackgroundTransparency = 0.2
				TweenService:Create(flashFrame, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {BackgroundTransparency = 0.9}):Play()
				task.wait(0.35)
			end
			gachaScale.Scale = 1.7
			TweenService:Create(gachaScale, TweenInfo.new(0.7, Enum.EasingStyle.Bounce), {Scale = 1}):Play()
			shakeUI(gachaContainer, 22, 0.9)
			showToast("🌟 " .. finalRarity:upper() .. "! " .. finalItem, rColor, 5)
			task.wait(4)
		elseif impactLevel == 2 then
			flashFrame.BackgroundColor3 = rColor
			flashFrame.BackgroundTransparency = 0.4
			TweenService:Create(flashFrame, TweenInfo.new(0.7), {BackgroundTransparency = 1}):Play()
			gachaScale.Scale = 1.35
			TweenService:Create(gachaScale, TweenInfo.new(0.45, Enum.EasingStyle.Bounce), {Scale = 1}):Play()
			shakeUI(gachaContainer, 10, 0.5)
			showToast("✨ " .. finalRarity:upper() .. "! " .. finalItem, rColor, 3.5)
			task.wait(3)
		elseif impactLevel == 1 then
			gachaScale.Scale = 1.18
			TweenService:Create(gachaScale, TweenInfo.new(0.35, Enum.EasingStyle.Back), {Scale = 1}):Play()
			task.wait(2.2)
		else
			gachaScale.Scale = 1.06
			TweenService:Create(gachaScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Scale = 1}):Play()
			task.wait(1.8)
		end

		TweenService:Create(gachaOverlay, TweenInfo.new(0.35), {BackgroundTransparency = 1}):Play()
		TweenService:Create(gachaScale, TweenInfo.new(0.3), {Scale = 0.8}):Play()
		TweenService:Create(rarityAura, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
		task.wait(0.35)

		lineL.BackgroundColor3 = Color3.fromRGB(115, 195, 235)
		lineR.BackgroundColor3 = Color3.fromRGB(115, 195, 235)
		gachaOverlay.Visible = false
		shared_isRollingActive = false
		if onComplete then onComplete() end
	end
end

