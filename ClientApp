local function getRarity(category: string, itemName: string): string
	if itemName == "None" or itemName == "[ NONE ]" then return "Common" end
	for rarity, items in pairs(GachaPools[category]) do
		for _, item in ipairs(items) do
			if item == itemName then return rarity end
		end
	end
	return "Common"
end

