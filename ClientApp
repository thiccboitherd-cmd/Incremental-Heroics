	frame.BackgroundColor3 = isEnemy and Color3.fromRGB(200, 45, 45) or Color3.fromRGB(40, 200, 70)
	frame.BorderSizePixel = 0
	local corner = Instance.new("UICorner", frame); corner.CornerRadius = UDim.new(1, 0)

	if isActive then
		local glow = Instance.new("UIStroke", frame)
		glow.Color = Color3.fromRGB(255, 255, 255)
		glow.Thickness = 3
		-- Pulsing glow for active combatant in turn order
		task.spawn(function()
			while frame.Parent do
				TweenService:Create(glow, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Transparency = 0.5}):Play()
				task.wait(2)
			end
		end)
	end

	local img = Instance.new("ImageLabel", frame)
	img.Size = UDim2.new(1, -4, 1, -4)
	img.Position = UDim2.new(0, 2, 0, 2)
	img.Image = portraitId
	img.BackgroundTransparency = 1
	local imgCorner = Instance.new("UICorner", img); imgCorner.CornerRadius = UDim.new(1, 0)
end

local function createCombatant(name: string, isEnemy: boolean, maxHp: number, portraitId: string, isBoss: boolean?)
	local container = isEnemy and shared_enemiesContainer or shared_alliesContainer

	local cardHeight = isBoss and 100 or 82
	local card = UIFramework.UIFrame.new("Card_"..name, Theme.Colors.Background, container)
	card.Gui.Size = UDim2.new(1, 0, 0, cardHeight)

	if isBoss then
		local bossStroke = Instance.new("UIStroke", card.Gui)
		bossStroke.Color = Color3.fromRGB(255, 80, 80)
		bossStroke.Thickness = 2
		bossStroke.Transparency = 0.3

		-- Boss label badge
		local bossBadge = Instance.new("Frame", card.Gui)
		bossBadge.Size = UDim2.new(0, 40, 0, 16)
		bossBadge.AnchorPoint = Vector2.new(1, 0)
		bossBadge.Position = UDim2.new(1, -5, 0, 5)
		bossBadge.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
		bossBadge.BorderSizePixel = 0
		local bbCorner = Instance.new("UICorner", bossBadge); bbCorner.CornerRadius = UDim.new(0, 4)
		local bbLabel = Instance.new("TextLabel", bossBadge)
		bbLabel.Size = UDim2.new(1, 0, 1, 0)
		bbLabel.BackgroundTransparency = 1
		bbLabel.Text = "BOSS"
		bbLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		bbLabel.Font = Enum.Font.GothamBlack
		bbLabel.TextSize = 9
	end

	local uiScale = Instance.new("UIScale", card.Gui)

	local portraitSize = isBoss and 80 or 62
	local portraitFrame = Instance.new("Frame", card.Gui)
	portraitFrame.Size = UDim2.new(0, portraitSize, 0, portraitSize)
	portraitFrame.Position = UDim2.new(0, 8, 0, (cardHeight - portraitSize)/2)
	portraitFrame.BackgroundColor3 = Theme.Colors.PanelHighlight
	portraitFrame.BorderSizePixel = 0
	local pCorner = Instance.new("UICorner", portraitFrame); pCorner.CornerRadius = UDim.new(1, 0)

	local portrait = Instance.new("ImageLabel", portraitFrame)
	portrait.Size = UDim2.new(1, -4, 1, -4)
	portrait.Position = UDim2.new(0, 2, 0, 2)
	portrait.Image = portraitId
	portrait.BackgroundTransparency = 1
	local imgCorner = Instance.new("UICorner", portrait); imgCorner.CornerRadius = UDim.new(1, 0)

	local statusRing = Instance.new("UIStroke", portraitFrame)
	statusRing.Thickness = 3
	statusRing.Transparency = 1

	local infoX = portraitSize + 16
	local nameLabel = UIFramework.UILabel.new("Name", card.Gui)
	nameLabel.Gui.Size = UDim2.new(1, -(infoX + 10), 0, 24)
	nameLabel.Gui.Position = UDim2.new(0, infoX, 0, 10)
	nameLabel:SetText(name)
	nameLabel.Gui.Font = Enum.Font.GothamBold
	nameLabel.Gui.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Gui.TextSize = isBoss and 15 or 13

	local hpBar = UIFramework.UIProgressBar.new("HPBar", card.Gui)
	hpBar.Gui.Size = UDim2.new(1, -(infoX + 10), 0, 14)
	hpBar.Gui.Position = UDim2.new(0, infoX, 0, 40)
	hpBar:SetProgress(1)
	local hpFill = hpBar.Gui:FindFirstChildWhichIsA("Frame")
	if hpFill then
		hpFill.BackgroundColor3 = isEnemy and Color3.fromRGB(220, 50, 50) or Color3.fromRGB(50, 220, 80)
	end

	local hpText = UIFramework.UILabel.new("HPText", hpBar.Gui)
	hpText.Gui.Size = UDim2.new(1, 0, 1, 0)
	hpText.Gui.ZIndex = 2
	hpText:SetText(maxHp .. " / " .. maxHp)
	hpText.Gui.TextSize = 10
	hpText.Gui.Font = Enum.Font.GothamBold
	hpText.Gui.TextColor3 = Color3.fromRGB(255, 255, 255)

	-- Status badge row
	local statusBadgeFrame = Instance.new("Frame", card.Gui)
	statusBadgeFrame.Size = UDim2.new(1, -(infoX + 10), 0, 16)
	statusBadgeFrame.Position = UDim2.new(0, infoX, 0, 58)
	statusBadgeFrame.BackgroundTransparency = 1
	local statusLayout = Instance.new("UIListLayout", statusBadgeFrame)
	statusLayout.FillDirection = Enum.FillDirection.Horizontal
	statusLayout.Padding = UDim.new(0, 4)

	local statusBadge = Instance.new("TextLabel", statusBadgeFrame)
	statusBadge.Size = UDim2.new(0, 0, 1, 0)
	statusBadge.AutomaticSize = Enum.AutomaticSize.X
	statusBadge.BackgroundTransparency = 1
	statusBadge.Text = ""
	statusBadge.Font = Enum.Font.GothamBold
	statusBadge.TextSize = 11

	local turnStroke = Instance.new("UIStroke", card.Gui)
	turnStroke.Color = Theme.Colors.PrimaryText
	turnStroke.Thickness = 2
	turnStroke.Transparency = 1

	local statusIcons = {
		Burn = {icon = "🔥", color = Color3.fromRGB(255, 100, 0)},
		Bleed = {icon = "🩸", color = Color3.fromRGB(200, 0, 0)},
		Stun = {icon = "⚡", color = Color3.fromRGB(255, 255, 0)},
		Erasure = {icon = "🚫", color = Color3.fromRGB(150, 150, 150)},
		Gravity = {icon = "⬇", color = Color3.fromRGB(180, 80, 255)},
		Brittle = {icon = "💢", color = Color3.fromRGB(180, 120, 50)},
	}

	local function applyStatus(statusType: string)
		local info = statusIcons[statusType]
		if info then
			statusRing.Transparency = 0
			statusRing.Color = info.color
			nameLabel.Gui.TextColor3 = info.color
			statusBadge.Text = info.icon .. " " .. statusType:upper()
			statusBadge.TextColor3 = info.color
		else
			statusRing.Transparency = 1
			nameLabel.Gui.TextColor3 = Theme.Colors.PrimaryText
			statusBadge.Text = ""
		end
	end

	local function triggerDamage()
		portraitFrame.BackgroundColor3 = Color3.fromRGB(255, 40, 40)
		TweenService:Create(portraitFrame, TweenInfo.new(0.45), {BackgroundColor3 = Theme.Colors.PanelHighlight}):Play()
		TweenService:Create(card.Gui, TweenInfo.new(0.05), {Rotation = 3}):Play()
		TweenService:Create(uiScale, TweenInfo.new(0.05), {Scale = 0.94}):Play()
		task.wait(0.05)
		TweenService:Create(card.Gui, TweenInfo.new(0.05), {Rotation = -3}):Play()
		task.wait(0.05)
		TweenService:Create(card.Gui, TweenInfo.new(0.08), {Rotation = 0}):Play()
		TweenService:Create(uiScale, TweenInfo.new(0.12), {Scale = 1}):Play()
	end

	return {
		Card = card.Gui,
		ApplyStatus = applyStatus,
		HPBar = hpBar,
		HPText = hpText,
		TriggerDamage = triggerDamage,
		TurnStroke = turnStroke,
		Portrait = portraitFrame
	}
end

