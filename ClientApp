	local function getMasteryLevel(type: string)
		local statVal = statsFolder:FindFirstChild(type .. "MasteryXP")
		if not statVal then return 1 end
		return math.floor(math.sqrt(statVal.Value / 100)) + 1
	end

	local function loadAvailableMoves()
		for _, child in ipairs(availScroll.Gui:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end

		local currentQuirk = statsFolder:WaitForChild("CurrentQuirk").Value
		local currentStyle = statsFolder:WaitForChild("CurrentStyle").Value
		local quirkLvl = getMasteryLevel("Quirk")
		local styleLvl = getMasteryLevel("Style")

		masteryTitle:SetText("◆ Quirk Mastery Lvl " .. quirkLvl .. "  |  Style Mastery Lvl " .. styleLvl)
		local unlockedMoves = {}

		if currentQuirk ~= "None" and currentQuirk ~= "[ NONE ]" then
			if MasteryMilestones.Quirk[currentQuirk] then
				for _, move in ipairs(MasteryMilestones.Quirk[currentQuirk]) do
					table.insert(unlockedMoves, {Data = move, IsQuirk = true, Mastered = quirkLvl >= move.ReqLvl})
				end
			else
				table.insert(unlockedMoves, {Data = {ReqLvl=1,Name=currentQuirk.." Alpha",Id="generic_quirk_1",Desc="Basic "..currentQuirk.." attack. 100% QF."}, IsQuirk=true, Mastered=true})
				table.insert(unlockedMoves, {Data = {ReqLvl=20,Name=currentQuirk.." Ultimate",Id="generic_quirk_2",Desc="Heavy "..currentQuirk.." attack. 250% QF."}, IsQuirk=true, Mastered=quirkLvl>=20})
			end
		end

		if MasteryMilestones.Style[currentStyle] then
			for _, move in ipairs(MasteryMilestones.Style[currentStyle]) do
				table.insert(unlockedMoves, {Data = move, IsQuirk = false, Mastered = styleLvl >= move.ReqLvl})
			end
		else
			table.insert(unlockedMoves, {Data = {ReqLvl=1,Name="Basic Strike",Id="basic_strike",Desc="100% STR. Reliable physical damage."}, IsQuirk=false, Mastered=true})
			table.insert(unlockedMoves, {Data = {ReqLvl=15,Name="Heavy Strike",Id="heavy_strike",Desc="180% STR. "..currentStyle.." mastery."}, IsQuirk=false, Mastered=styleLvl>=15})
		end

		for _, mData in ipairs(unlockedMoves) do
			local move = mData.Data
			local btn = UIFramework.UIButton.new("Move_"..move.Id, "", Theme.Colors.PanelHighlight, availScroll.Gui)
			btn.Gui.Size = UDim2.new(1, 0, 0, 56)

			-- Rarity stripe on left for quirk moves
			if mData.IsQuirk and mData.Mastered then
				local quirkStripe = Instance.new("Frame", btn.Gui)
				quirkStripe.Size = UDim2.new(0, 3, 1, 0)
				quirkStripe.BackgroundColor3 = RarityColors.Epic; quirkStripe.BorderSizePixel = 0
				local qs = Instance.new("UICorner", quirkStripe); qs.CornerRadius = UDim.new(0, 4)
			end

			local mTitle = UIFramework.UILabel.new("Title", btn.Gui)
			mTitle.Gui.Size = UDim2.new(0.7, 0, 0, 22)
			mTitle.Gui.Position = UDim2.new(0, 12, 0, 6)
			mTitle:SetText(move.Name)
			mTitle.Gui.Font = Enum.Font.GothamBold
			mTitle.Gui.TextXAlignment = Enum.TextXAlignment.Left
			mTitle.Gui.TextSize = 13

			local reqLabel = UIFramework.UILabel.new("Req", btn.Gui)
			reqLabel.Gui.Size = UDim2.new(0.28, 0, 0, 22)
			reqLabel.Gui.Position = UDim2.new(0.72, 0, 0, 6)
			reqLabel:SetText("Lvl " .. move.ReqLvl)
			reqLabel.Gui.TextXAlignment = Enum.TextXAlignment.Right
			reqLabel.Gui.Font = Enum.Font.GothamBold
			reqLabel.Gui.TextSize = 12

			local mDesc = UIFramework.UILabel.new("Desc", btn.Gui)
			mDesc.Gui.Size = UDim2.new(1, -20, 0, 20)
			mDesc.Gui.Position = UDim2.new(0, 12, 0, 30)
			mDesc:SetText(move.Desc)
			mDesc.Gui.TextSize = 11
			mDesc.Gui.TextXAlignment = Enum.TextXAlignment.Left
			mDesc.Gui.Font = Enum.Font.Gotham

			if not mData.Mastered then
				mTitle.Gui.TextColor3 = Theme.Colors.LockedText
				mDesc.Gui.TextColor3 = Theme.Colors.LockedText
				reqLabel.Gui.TextColor3 = Color3.fromRGB(200, 80, 80)
				btn.Gui.Active = false
				btn.Gui.BackgroundTransparency = 0.5
			else
				mTitle.Gui.TextColor3 = mData.IsQuirk and RarityColors.Epic or Theme.Colors.PrimaryText
				mDesc.Gui.TextColor3 = Theme.Colors.TextMuted
				reqLabel.Gui.TextColor3 = Color3.fromRGB(80, 220, 100)
				applyHoverEffect(btn.Gui, 1.03, 10)

				btn:OnClick(function()
					shared_activeSlotBtns[shared_selectedSlotIndex]:SetText(move.Name)
					EquipMoveEvent:FireServer(shared_selectedSlotIndex, move.Id)
					showToast("✔ Equipped: " .. move.Name .. " → Slot " .. shared_selectedSlotIndex, mData.IsQuirk and RarityColors.Epic or Theme.Colors.PrimaryText)
				end)
			end
		end
	end

	statsFolder:WaitForChild("CurrentQuirk").Changed:Connect(function()
		for i, btn in ipairs(shared_activeSlotBtns) do btn:SetText("SLOT "..i); EquipMoveEvent:FireServer(i, "Empty") end
		loadAvailableMoves()
	end)
	statsFolder:WaitForChild("CurrentStyle").Changed:Connect(function()
		for i, btn in ipairs(shared_activeSlotBtns) do btn:SetText("SLOT "..i); EquipMoveEvent:FireServer(i, "Empty") end
		loadAvailableMoves()
	end)
	loadAvailableMoves()
end

